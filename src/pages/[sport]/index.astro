---
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";
import { loadSetsManifest } from "../../lib/sets";

export async function getStaticPaths() {
  const { manifest } = loadSetsManifest();
  return Object.keys(manifest).map((sport) => ({ params: { sport } }));
}

const { sport } = Astro.params;
const { manifest } = loadSetsManifest();

const setsObj = manifest[sport] ?? {};
const sets = Object.keys(setsObj).sort((a, b) => a.localeCompare(b));
---

<Layout title={`${sport} • BradyRip Card Vault`}>
  <main class="mx-auto max-w-6xl px-4 py-10">
    <div class="card" style="padding:16px;">
      <div class="kicker">
        <a class="btn" href="/">← Home</a>
      </div>
      <h1 class="h1" style="margin-top:10px; text-transform: capitalize;">
        {sport}
      </h1>
      <p class="subtle" style="margin-top:10px;">
        Pick a set to view pictures.
      </p>
    </div>

    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {sets.map((setSlug) => {
        const imgs = setsObj[setSlug] ?? [];
        const cover = imgs[0]?.thumb;
        return (
          <a
            href={`/${sport}/${setSlug}/`}
            class="group rounded-2xl bg-zinc-950 ring-1 ring-zinc-800 hover:ring-zinc-600 transition p-4"
          >
            <div class="text-sm text-zinc-300">{setSlug}</div>

            {cover ? (
              <img
                src={cover}
                alt={`${setSlug} cover`}
                class="mt-3 w-full rounded-xl object-cover ring-1 ring-zinc-800"
                style="height: 220px;"
                loading="lazy"
                decoding="async"
              />
            ) : (
              <div
                class="mt-3 rounded-xl ring-1 ring-zinc-800 bg-zinc-900/30 flex items-center justify-center text-sm text-zinc-400"
                style="height:220px;"
              >
                No cover image
              </div>
            )}

            <div class="mt-3 text-sm text-zinc-400">{imgs.length} image{imgs.length === 1 ? "" : "s"}</div>
          </a>
        );
      })}
    </div>
  </main>
</Layout>