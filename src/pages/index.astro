---
import "../styles/global.css";
import { loadSetsManifest } from "../lib/sets";

const { manifest, generatedAt } = loadSetsManifest();

const sports = [
  { slug: "baseball", label: "Baseball", icon: "⚾" },
  { slug: "basketball", label: "Basketball", icon: "🏀" },
  { slug: "football", label: "Football", icon: "🏈" },
];

const buildStamp = new Date().toISOString();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Card Gallery</title>
  </head>

  <body class="min-h-screen bg-zinc-950 text-zinc-100">
    <main class="mx-auto max-w-6xl px-4 py-10">
      <div class="rounded-3xl bg-gradient-to-b from-zinc-900/40 to-zinc-950 ring-1 ring-zinc-800 p-8 relative overflow-hidden">
        <div class="absolute -top-24 -right-20 h-72 w-72 rounded-full bg-indigo-500/10 blur-3xl"></div>
        <div class="absolute -bottom-20 -left-16 h-72 w-72 rounded-full bg-emerald-500/10 blur-3xl"></div>

        <div class="inline-flex items-center gap-2 rounded-full bg-zinc-900/60 ring-1 ring-zinc-800 px-3 py-1 text-sm text-zinc-200">
          ✨ BradyRip Card Vault
        </div>

        <h1 class="h1" style="margin-top:14px;">Browse my sets and card pictures.</h1>

        <p class="subtle" style="margin-top:10px; max-width: 60ch;">
          Choose a sport → choose a set → tap a card to zoom.
        </p>

        <div class="mt-8 grid gap-6 lg:grid-cols-3">
          {/* LEFT: sport tiles */}
          <div class="lg:col-span-2">
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {sports.map((s) => {
                const setCount = Object.keys(manifest?.[s.slug] ?? {}).length;
                return (
                  <a
                    href={`/${s.slug}/`}
                    class="group rounded-2xl bg-zinc-950 ring-1 ring-zinc-800 hover:ring-zinc-600 transition p-6"
                  >
                    <div class="text-sm text-zinc-300">{s.icon} {s.label}</div>
                    <div class="mt-2 text-xl font-semibold tracking-tight">Browse sets →</div>
                    <div class="mt-2 text-sm text-zinc-400">
                      {setCount} set{setCount === 1 ? "" : "s"} available.
                    </div>
                  </a>
                );
              })}
            </div>

            {/* About */}
            <div class="card" style="padding:16px; margin-top:18px;">
              <div class="kicker">About</div>
              <div class="subtle" style="margin-top:6px;">
                Updated regularly — new uploads show up automatically.
              </div>
            </div>

            {/* Contact */}
            <div class="mt-4 card" style="padding: 14px 16px;">
              <div class="kicker">Contact</div>
              <p class="subtle" style="margin: 10px 0 0;">
                Email:
                <a class="btn" style="margin-left: 8px;" href="mailto:bradyripcards@gmail.com">
                  bradyripcards@gmail.com
                </a>
              </p>
            </div>

            <div class="mt-3 text-xs text-zinc-500">
              Build: {generatedAt ? new Date(generatedAt).toLocaleString() : buildStamp}
            </div>
          </div>

          {/* RIGHT: Card of the Week (random from sets.json) */}
          <aside class="lg:col-span-1">
            <div class="text-center text-sm text-zinc-300">🔥 Random Card</div>

            <div class="mt-3 flex justify-center lg:justify-end">
              <div class="w-full max-w-sm rounded-2xl bg-zinc-950/60 ring-1 ring-zinc-800 p-3">
                <button id="cotwOpen" type="button" class="block w-full" aria-label="Open Random Card">
                  <img
                    id="cotwImg"
                    alt="Random Card"
                    class="mx-auto w-full max-w-[320px] rounded-xl object-contain ring-1 ring-zinc-800"
                    loading="lazy"
                    decoding="async"
                  />
                </button>

                <div id="cotwMeta" class="mt-2 text-center text-xs text-zinc-500"></div>

                <div class="mt-3 flex justify-center">
                  <a
                    id="cotwBtn"
                    href="/"
                    class="inline-flex items-center rounded-full bg-zinc-900/60 ring-1 ring-zinc-800 px-4 py-2 text-sm text-zinc-200 hover:ring-zinc-600 transition"
                  >
                    Go to set →
                  </a>
                </div>
              </div>
            </div>

            <dialog
              id="cotwDialog"
              class="backdrop:bg-black/70 rounded-3xl bg-zinc-950 text-zinc-100 ring-1 ring-zinc-800 p-0"
              style="width:min(92vw,720px); margin:auto;"
            >
              <style is:inline>
                #cotwDialog[open] { position: fixed; inset: 0; margin: auto; }
              </style>

              <div class="p-4 sm:p-6">
                <div class="flex items-center justify-between gap-3">
                  <div class="text-sm text-zinc-300">Random Card</div>

                  <form method="dialog" class="flex items-center gap-2">
                    <a id="cotwSetLink" class="btn" href="/">Go to set →</a>
                    <button class="btn" value="cancel" aria-label="Close">Close</button>
                  </form>
                </div>

                <div class="mt-4 flex justify-center">
                  <img
                    id="cotwZoomImg"
                    alt="Random Card zoomed"
                    class="block rounded-2xl ring-1 ring-zinc-800"
                    style="max-height:70vh; width:auto;"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              </div>
            </dialog>
          </aside>
        </div>

        <script is:inline>
          (async () => {
            const STORAGE_KEY = "bradyrip_randcard_v1";
            const WEEK_MS = 7 * 24 * 60 * 60 * 1000;

            const img = document.getElementById("cotwImg");
            const meta = document.getElementById("cotwMeta");
            const btn = document.getElementById("cotwBtn");

            const openBtn = document.getElementById("cotwOpen");
            const dlg = document.getElementById("cotwDialog");
            const zoomImg = document.getElementById("cotwZoomImg");
            const setLink = document.getElementById("cotwSetLink");

            function now(){ return Date.now(); }

            function loadCached() {
              try {
                const raw = localStorage.getItem(STORAGE_KEY);
                if (!raw) return null;
                const parsed = JSON.parse(raw);
                if (!parsed || !parsed.pick || !parsed.expiresAt) return null;
                if (now() > parsed.expiresAt) return null;
                return parsed.pick;
              } catch { return null; }
            }

            function saveCached(pick) {
              try {
                localStorage.setItem(STORAGE_KEY, JSON.stringify({
                  pick,
                  expiresAt: now() + WEEK_MS,
                  savedAt: now(),
                }));
              } catch {}
            }

            function applyPick(pick) {
              if (!pick) return;
              if (img) img.src = pick.thumb;
              if (zoomImg) zoomImg.src = pick.full || pick.thumb;
              if (meta) meta.textContent = `${pick.sport} • ${pick.setSlug}`;
              const href = `/${pick.sport}/${pick.setSlug}/`;
              if (btn) btn.href = href;
              if (setLink) setLink.href = href;
            }

            // modal wiring
            if (dlg && openBtn) {
              openBtn.addEventListener("click", () => {
                if (typeof dlg.showModal === "function") dlg.showModal();
              });

              dlg.addEventListener("click", (e) => {
                const r = dlg.getBoundingClientRect();
                const clickedOutside =
                  e.clientX < r.left || e.clientX > r.right || e.clientY < r.top || e.clientY > r.bottom;
                if (clickedOutside) dlg.close();
              });
            }

            try {
              const cached = loadCached();
              if (cached) { applyPick(cached); return; }

              const res = await fetch("/sets.json", { cache: "no-store" });
              if (!res.ok) return;

              const data = await res.json();
              const manifest = data?.manifest;
              if (!manifest) return;

              // Flatten to a pool of images; pick random from first N for speed.
              const pool = [];
              for (const sport of Object.keys(manifest)) {
                for (const setSlug of Object.keys(manifest[sport] || {})) {
                  const imgs = manifest[sport][setSlug] || [];
                  for (const i of imgs) {
                    if (i?.thumb) pool.push({ ...i, sport, setSlug });
                    if (pool.length >= 400) break;
                  }
                  if (pool.length >= 400) break;
                }
                if (pool.length >= 400) break;
              }

              if (pool.length === 0) return;
              const pick = pool[Math.floor(Math.random() * pool.length)];

              saveCached(pick);
              applyPick(pick);
            } catch {}
          })();
        </script>

      </div>
    </main>
  </body>
</html>