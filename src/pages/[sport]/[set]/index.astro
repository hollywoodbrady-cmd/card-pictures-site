---
import { loadSetsManifest } from "../../../lib/sets";

export async function getStaticPaths() {
  const { manifest } = loadSetsManifest();
  const paths: { params: { sport: string; set: string } }[] = [];

  for (const sport of Object.keys(manifest)) {
    for (const set of Object.keys(manifest[sport] ?? {})) {
      paths.push({ params: { sport, set } });
    }
  }

  return paths;
}

const { sport, set } = Astro.params;
const { manifest } = loadSetsManifest();

const images = manifest[sport]?.[set] ?? [];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{set} • {sport} • Card Pictures</title>
    <style>
      body { font-family: system-ui, sans-serif; margin: 0; }
      header { padding: 16px 20px; border-bottom: 1px solid #e5e5e5; }
      main { padding: 20px; max-width: 1200px; margin: 0 auto; }
      a { color: inherit; }
      .crumbs { font-size: 13px; color: #555; margin-bottom: 10px; }
      .meta { color: #666; font-size: 12px; margin-top: 6px; }
      .grid { display: grid; gap: 10px; grid-template-columns: repeat(auto-fill, minmax(170px, 1fr)); }
      .thumb {
        display: block;
        border: 1px solid #e5e5e5;
        border-radius: 10px;
        overflow: hidden;
        background: #f6f6f6;
        text-decoration: none;
      }
      .thumb:hover { border-color: #bbb; }
      img { width: 100%; height: 260px; object-fit: cover; display:block; }
      .empty { padding: 16px; border: 1px dashed #ccc; border-radius: 10px; color: #555; }
    </style>
  </head>
  <body>
    <header>
      <div style="max-width:1200px;margin:0 auto;">
        <div class="crumbs">
          <a href="/">Home</a> / <a href={`/${sport}/`} style="text-transform:capitalize;">{sport}</a> / <span>{set}</span>
        </div>
        <h1 style="margin:0;font-size:22px;">{set}</h1>
        <div class="meta">{images.length} image{images.length === 1 ? "" : "s"}</div>
      </div>
    </header>

    <main>
      {images.length === 0 ? (
        <div class="empty">No images found for this set in <code>thumbs/</code>.</div>
      ) : (
        <div class="grid">
          {images.map((img) => (
            <a class="thumb" href={img.full} target="_blank" rel="noreferrer">
              <img
                src={img.thumb}
                loading="lazy"
                alt={img.file ?? "card image"}
                onerror="this.onerror=null; this.src=this.closest('a').href;"
              />
            </a>
          ))}
        </div>
      )}
    </main>
  </body>
</html>