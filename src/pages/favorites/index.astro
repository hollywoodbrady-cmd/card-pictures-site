---
import "../../styles/global.css";
import fs from "node:fs/promises";
import path from "node:path";

function isImageFile(f: string) {
  return /\.(webp|png|jpe?g|gif)$/i.test(f);
}
async function dirExists(p: string) {
  try { return (await fs.stat(p)).isDirectory(); } catch { return false; }
}

function toUrl(sport: string, set: string, sub: string | null, file: string) {
  const mid = sub ? `/${sub}` : "";
  return `/cards/${sport}/${set}${mid}/${file}`;
}

// Key used to pair front/back.
function cardKey(file: string) {
  return file.replace(/\.[^.]+$/, "").replace(/__front$/i, "").replace(/__back$/i, "");
}

const baseDir = path.join(process.cwd(), "public", "cards");
const sportsWanted = ["baseball", "basketball", "football"];

type Fav = {
  title: string;
  sport: string;
  set: string;
  setHref: string;
  urlThumb: string;
  urlFront: string;
  urlBack: string | null;
};

const cards: Fav[] = [];

const baseEntries = await fs.readdir(baseDir, { withFileTypes: true }).catch(() => []);
const sportFolder = (sport: string) =>
  baseEntries.find((e) => e.isDirectory() && e.name.toLowerCase() === sport)?.name ?? sport;

for (const sport of sportsWanted) {
  const folder = sportFolder(sport);
  const sportDir = path.join(baseDir, folder);
  const setEntries = await fs.readdir(sportDir, { withFileTypes: true }).catch(() => []);
  const sets = setEntries.filter((e) => e.isDirectory()).map((e) => e.name);

  for (const set of sets) {
    const setDir = path.join(sportDir, set);

    const frontWebpDir = path.join(setDir, "front-webp");
    const backWebpDir  = path.join(setDir, "back-webp");
    const thumbsDir    = path.join(setDir, "thumbs");

    const hasFront = await dirExists(frontWebpDir);
    if (!hasFront) continue;

    const hasBack = await dirExists(backWebpDir);
    const hasThumbs = await dirExists(thumbsDir);

    const fullDir = frontWebpDir;
    const fullSub = "front-webp";
    const thumbDir = hasThumbs ? thumbsDir : fullDir;
    const thumbSub = hasThumbs ? "thumbs" : fullSub;

    // build back map
    const backByKey = new Map<string, string>();
    if (hasBack) {
      const backs = (await fs.readdir(backWebpDir).catch(() => [])).filter(isImageFile);
      for (const b of backs) backByKey.set(cardKey(b), b);
    }

    // read front files and only keep favorites
    const fronts = (await fs.readdir(fullDir).catch(() => []))
      .filter(isImageFile)
      .filter((f) => /(^|__)fav(__|$)/i.test(f)); // <-- auto rule: filename contains __fav

    if (fronts.length === 0) continue;

    // thumbs map
    const thumbs = (await fs.readdir(thumbDir).catch(() => [])).filter(isImageFile);
    const thumbByBase = new Map<string, string>();
    for (const t of thumbs) thumbByBase.set(t.replace(/\.[^.]+$/, ""), t);

    for (const frontImg of fronts) {
      const key = cardKey(frontImg);
      const backImg = hasBack ? (backByKey.get(key) ?? null) : null;

      const base = frontImg.replace(/\.[^.]+$/, "");
      const thumbName = thumbByBase.get(base) ?? frontImg;

      const title = frontImg
        .replace(/\.[^.]+$/, "")
        .replace(/__fav/i, "")
        .replace(/__front$/i, "")
        .replace(/__+/g, " ")
        .replace(/[-_]+/g, " ")
        .trim();

      cards.push({
        title,
        sport: folder,
        set,
        setHref: `/${sport}/${set}/`,
        urlThumb: toUrl(folder, set, thumbSub, thumbName),
        urlFront: toUrl(folder, set, fullSub, frontImg),
        urlBack: backImg ? toUrl(folder, set, "back-webp", backImg) : null,
      });
    }
  }
}

// sort: baseball -> basketball -> football, then set, then title
const sportOrder = new Map([["baseball", 1], ["basketball", 2], ["football", 3]]);
cards.sort((a, b) => {
  const sa = sportOrder.get(a.sport.toLowerCase()) ?? 99;
  const sb = sportOrder.get(b.sport.toLowerCase()) ?? 99;
  if (sa !== sb) return sa - sb;
  const s = a.set.localeCompare(b.set, undefined, { sensitivity: "base" });
  if (s !== 0) return s;
  return a.title.localeCompare(b.title, undefined, { sensitivity: "base" });
});
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Favorites</title>
  </head>

  <body class="min-h-screen bg-zinc-950 text-zinc-100">
    <main class="mx-auto max-w-6xl px-4 py-10">
      <div class="flex items-center justify-between gap-4">
        <a href="/" class="text-sm text-zinc-400 hover:text-zinc-200">← Home</a>
        <div class="text-sm text-zinc-400">Favorites • {cards.length}</div>
      </div>

      <div class="mt-6">
        <h1 class="text-3xl font-semibold tracking-tight">Favorites</h1>
        <p class="mt-2 text-zinc-300">My favorite cards</p>
      </div>

      {cards.length === 0 ? (
        <div class="mt-6 rounded-2xl ring-1 ring-zinc-800 p-6 text-zinc-300">
          No favorites yet. Rename a card file to include <code class="rounded bg-zinc-900 px-2 py-1 ring-1 ring-zinc-800">__fav</code>.
        </div>
      ) : (
        <>
          <section class="mt-6 flex flex-wrap gap-3" id="grid">
            {cards.map((c, i) => (
              <button
                type="button"
                class="tile group w-[120px] sm:w-[135px] md:w-[150px] rounded-xl ring-1 ring-zinc-800 bg-zinc-950 overflow-hidden hover:ring-zinc-600 transition"
                data-open={i}
                aria-label={`Open ${c.title}`}
              >
                <div class="aspect-[3/4] bg-zinc-900/25">
                  <img
                    src={c.urlThumb}
                    alt={c.title}
                    loading="lazy"
                    class="h-full w-full object-contain p-1.5 group-hover:scale-[1.02] transition"
                  />
                </div>
                <div class="px-2 py-2">
                  <div class="text-xs font-medium text-zinc-200 truncate">{c.title}</div>
                  <div class="text-[10px] text-zinc-400 truncate">{c.sport} • {c.set}</div>
                  <div class="mt-1 flex flex-wrap gap-1">
                    {c.urlBack ? <span class="pill">2-SIDED</span> : null}
                    <span class="pill">FAV</span>
                  </div>
                </div>
              </button>
            ))}
          </section>

          {/* LIGHTBOX */}
          <div id="lightbox" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 p-4" aria-hidden="true">
            <div class="absolute inset-0" data-close></div>

            <div class="relative w-full max-w-4xl">
              <div class="rounded-2xl bg-zinc-950 ring-1 ring-zinc-800 overflow-hidden">
                <div class="flex items-center justify-between px-4 py-3 border-b border-zinc-800">
                  <div class="text-sm text-zinc-300 truncate" id="lb-label"></div>
                  <button type="button" class="text-sm text-zinc-300 hover:text-white rounded-lg px-3 py-1.5 ring-1 ring-zinc-700/70 hover:ring-zinc-500" data-close>
                    Close
                  </button>
                </div>

                <div class="bg-black/30">
                  <img id="lb-img" src="" alt="" class="w-full max-h-[80vh] object-contain" />
                </div>

                <div class="flex flex-wrap items-center justify-between gap-2 px-4 py-3 border-t border-zinc-800">
                  <button type="button" class="text-sm text-zinc-300 hover:text-white rounded-lg px-3 py-1.5 ring-1 ring-zinc-700/70 hover:ring-zinc-500" id="lb-prev">← Prev</button>

                  <button type="button" class="text-sm text-zinc-300 hover:text-white rounded-lg px-3 py-1.5 ring-1 ring-zinc-700/70 hover:ring-zinc-500" id="lb-flip">View Back</button>

                  <a id="lb-set" href="/" class="text-sm text-zinc-200 rounded-lg px-3 py-1.5 ring-1 ring-zinc-700/70 hover:ring-zinc-500">Go to set →</a>

                  <div class="text-xs text-zinc-400" id="lb-count"></div>

                  <button type="button" class="text-sm text-zinc-300 hover:text-white rounded-lg px-3 py-1.5 ring-1 ring-zinc-700/70 hover:ring-zinc-500" id="lb-next">Next →</button>
                </div>
              </div>
            </div>
          </div>

          <style>
            .pill{
              font-size:10px;
              padding:2px 6px;
              border-radius:999px;
              border:1px solid rgba(39,39,42,1);
              background:rgba(24,24,27,.6);
              color:rgba(212,212,216,1);
            }
          </style>

          <script define:vars={{ cards }}>
            const fronts = cards.map((c) => c.urlFront);
            const backs  = cards.map((c) => c.urlBack);
            const labels = cards.map((c) => c.title || "");
            const setHrefs = cards.map((c) => c.setHref || "/");

            const lb = document.getElementById("lightbox");
            const lbImg = document.getElementById("lb-img");
            const lbLabel = document.getElementById("lb-label");
            const lbCount = document.getElementById("lb-count");
            const prevBtn = document.getElementById("lb-prev");
            const nextBtn = document.getElementById("lb-next");
            const flipBtn = document.getElementById("lb-flip");
            const setBtn  = document.getElementById("lb-set");

            let idx = 0;
            let side = "front";

            function render() {
              const backUrl = backs[idx];
              const showBack = side === "back" && backUrl;
              lbImg.src = showBack ? backUrl : fronts[idx];
              const suffix = backUrl ? (showBack ? " • Back" : " • Front") : "";
              lbLabel.textContent = (labels[idx] || "Favorite") + suffix;
              lbCount.textContent = `${idx + 1} / ${fronts.length}`;

              if (flipBtn) {
                const hasBack = !!backUrl;
                flipBtn.disabled = !hasBack;
                flipBtn.style.opacity = hasBack ? "1" : "0.35";
                flipBtn.textContent = hasBack ? (showBack ? "View Front" : "View Back") : "No Back";
              }
              if (setBtn) setBtn.href = setHrefs[idx] || "/";
            }

            function open(i) {
              idx = (i + fronts.length) % fronts.length;
              side = "front";
              render();
              lb.classList.remove("hidden");
              lb.classList.add("flex");
              lb.setAttribute("aria-hidden", "false");
            }

            function close() {
              lb.classList.add("hidden");
              lb.classList.remove("flex");
              lb.setAttribute("aria-hidden", "true");
              lbImg.src = "";
            }

            document.querySelectorAll("[data-open]").forEach((btn) => {
              btn.addEventListener("click", () => open(parseInt(btn.dataset.open, 10)));
            });

            lb.querySelectorAll("[data-close]").forEach((el) => el.addEventListener("click", close));

            prevBtn.addEventListener("click", () => { idx = (idx - 1 + fronts.length) % fronts.length; side="front"; render(); });
            nextBtn.addEventListener("click", () => { idx = (idx + 1) % fronts.length; side="front"; render(); });

            flipBtn?.addEventListener("click", () => {
              if (!backs[idx]) return;
              side = (side === "front") ? "back" : "front";
              render();
            });

            window.addEventListener("keydown", (e) => {
              if (!lb || lb.classList.contains("hidden")) return;
              if (e.key === "Escape") close();
              if (e.key === "ArrowLeft") { idx = (idx - 1 + fronts.length) % fronts.length; side="front"; render(); }
              if (e.key === "ArrowRight") { idx = (idx + 1) % fronts.length; side="front"; render(); }
              if (e.key.toLowerCase() === "b") {
                if (!backs[idx]) return;
                side = (side === "front") ? "back" : "front";
                render();
              }
            });
          </script>
        </>
      )}
    </main>
  </body>
</html>
