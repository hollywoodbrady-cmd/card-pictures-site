---
import "../../styles/global.css";
import fs from "node:fs/promises";
import path from "node:path";

function isImageFile(f: string) {
  return /\.(webp|png|jpe?g|gif)$/i.test(f);
}

async function dirExists(p: string) {
  try {
    const st = await fs.stat(p);
    return st.isDirectory();
  } catch {
    return false;
  }
}

function toUrl(sub: string | null, file: string) {
  const mid = sub ? `/${sub}` : "";
  return `/psa${mid}/${file}`;
}

// Pairing key: strips extension + trailing front/back markers
function cardKey(file: string) {
  return file
    .replace(/\.[^.]+$/, "")
    .replace(/(__|_)front$/i, "")
    .replace(/(__|_)back$/i, "");
}

const psaRoot = path.join(process.cwd(), "public", "psa");

// Prefer these if present (matches your folder layout)
const frontDir = path.join(psaRoot, "front-webp");
const backDir = path.join(psaRoot, "back-webp");
const thumbsDir = path.join(psaRoot, "thumbs");

// Fallback to root if front-webp doesn’t exist
const hasFront = await dirExists(frontDir);
const hasBack = await dirExists(backDir);
const hasThumbs = await dirExists(thumbsDir);

const fullDir = hasFront ? frontDir : psaRoot;
const fullSub = hasFront ? "front-webp" : null;

const thumbDir = hasThumbs ? thumbsDir : fullDir;
const thumbSub = hasThumbs ? "thumbs" : fullSub;

// Read fronts
const fullFiles = (await fs.readdir(fullDir).catch(() => [])).filter(isImageFile);
fullFiles.sort((a, b) => a.localeCompare(b, undefined, { numeric: true, sensitivity: "base" }));

// Read thumbs
const thumbFiles = (await fs.readdir(thumbDir).catch(() => [])).filter(isImageFile);
thumbFiles.sort((a, b) => a.localeCompare(b, undefined, { numeric: true, sensitivity: "base" }));

const thumbByBase = new Map<string, string>();
for (const f of thumbFiles) thumbByBase.set(f.replace(/\.[^.]+$/, ""), f);

// Read backs (optional)
const backByKey = new Map<string, string>();
if (hasBack) {
  const backFiles = (await fs.readdir(backDir).catch(() => [])).filter(isImageFile);
  for (const f of backFiles) backByKey.set(cardKey(f), f);
}

const cards = fullFiles.map((frontImg) => {
  const key = cardKey(frontImg);
  const backImg = hasBack ? (backByKey.get(key) ?? null) : null;

  const base = frontImg.replace(/\.[^.]+$/, "");
  const thumbName = thumbByBase.get(base) ?? frontImg;

  // label (for the lightbox header)
  const label = base
    .replace(/(__|_)front$/i, "")
    .replace(/[-_]+/g, " ")
    .trim();

  return {
    frontImg,
    backImg,
    urlFront: toUrl(fullSub, frontImg),
    urlBack: backImg ? toUrl("back-webp", backImg) : null,
    urlThumb: toUrl(thumbSub, thumbName),
    label,
    hasBack: Boolean(backImg),
  };
});

const title = "PSA Graded Cards";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>

  <body class="min-h-screen bg-zinc-950 text-zinc-100">
    <main class="mx-auto max-w-6xl px-4 py-10">
      <div class="rounded-3xl bg-gradient-to-b from-zinc-900/40 to-zinc-950 ring-1 ring-zinc-800 p-8">
        <div class="flex items-center justify-between gap-4">
          <a class="btn" href="/">← Home</a>
          <div class="text-xs text-zinc-500">
            {cards.length} card{cards.length === 1 ? "" : "s"}
          </div>
        </div>

        <h1 class="h1" style="margin-top:14px;">PSA Graded Cards</h1>
        <p class="subtle" style="margin-top:10px;">
         
        </p>

        {cards.length === 0 ? (
          <div class="mt-6 rounded-2xl ring-1 ring-zinc-800 p-6 text-zinc-300">
            No PSA cards found yet.
          </div>
        ) : (
          <>
            {/* GRID */}
            <section class="mt-6 flex flex-wrap gap-3" id="grid">
              {cards.map((c, i) => (
                <button
                  type="button"
                  class="tile group w-[120px] sm:w-[135px] md:w-[150px] rounded-xl ring-1 ring-zinc-800 bg-zinc-950 overflow-hidden hover:ring-zinc-600 transition"
                  data-open={i}
                  aria-label={`Open ${c.label}`}
                >
                  <div class="aspect-[3/4] bg-zinc-900/25">
                    <img
                      src={c.urlThumb}
                      alt={c.label}
                      loading="lazy"
                      class="h-full w-full object-contain p-1.5 group-hover:scale-[1.02] transition"
                    />
                  </div>
                  <div class="px-2 py-2">
                    <div class="text-[10px] text-zinc-400 truncate">{c.label}</div>
                  </div>
                </button>
              ))}
            </section>

            {/* LIGHTBOX */}
            <div
              id="lightbox"
              class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 p-4"
              aria-hidden="true"
            >
              <div class="absolute inset-0" data-close></div>

              <div class="relative w-full max-w-4xl">
                <div class="rounded-2xl bg-zinc-950 ring-1 ring-zinc-800 overflow-hidden">
                  <div class="flex items-center justify-between px-4 py-3 border-b border-zinc-800">
                    <div class="text-sm text-zinc-300 truncate" id="lb-label"></div>
                    <button
                      type="button"
                      class="text-sm text-zinc-300 hover:text-white rounded-lg px-3 py-1.5 ring-1 ring-zinc-700/70 hover:ring-zinc-500"
                      data-close
                    >
                      Close
                    </button>
                  </div>

                  <div class="bg-black/30">
                    <img id="lb-img" src="" alt="" class="w-full max-h-[80vh] object-contain" />
                  </div>

                  <div class="flex items-center justify-between px-4 py-3 border-t border-zinc-800">
                    <button type="button" class="text-sm text-zinc-300 hover:text-white rounded-lg px-3 py-1.5 ring-1 ring-zinc-700/70 hover:ring-zinc-500" id="lb-prev">← Prev</button>
                    <button type="button" class="text-sm text-zinc-300 hover:text-white rounded-lg px-3 py-1.5 ring-1 ring-zinc-700/70 hover:ring-zinc-500" id="lb-flip">View Back</button>
                    <div class="text-xs text-zinc-400" id="lb-count"></div>
                    <button type="button" class="text-sm text-zinc-300 hover:text-white rounded-lg px-3 py-1.5 ring-1 ring-zinc-700/70 hover:ring-zinc-500" id="lb-next">Next →</button>
                  </div>
                </div>
              </div>
            </div>

            <script define:vars={{ cards }}>
              const fronts = cards.map((c) => c.urlFront);
              const backs  = cards.map((c) => c.urlBack);
              const labels = cards.map((c) => c.label);

              const lb = document.getElementById("lightbox");
              const lbImg = document.getElementById("lb-img");
              const lbLabel = document.getElementById("lb-label");
              const lbCount = document.getElementById("lb-count");
              const prevBtn = document.getElementById("lb-prev");
              const nextBtn = document.getElementById("lb-next");
              const flipBtn = document.getElementById("lb-flip");

              let idx = 0;
              let side = "front";

              function render() {
                const backUrl = backs[idx];
                const showBack = side === "back" && backUrl;
                const url = showBack ? backUrl : fronts[idx];

                lbImg.src = url;
                lbImg.alt = labels[idx];

                const suffix = backUrl ? (showBack ? " • Back" : " • Front") : "";
                lbLabel.textContent = labels[idx] + suffix;

                lbCount.textContent = `${idx + 1} / ${fronts.length}`;

                if (flipBtn) {
                  const hasBack = !!backUrl;
                  flipBtn.disabled = !hasBack;
                  flipBtn.style.opacity = hasBack ? "1" : "0.35";
                  flipBtn.textContent = hasBack ? (showBack ? "View Front" : "View Back") : "No Back";
                }
              }

              function open(i) {
                idx = (i + fronts.length) % fronts.length;
                side = "front";
                render();
                lb.classList.remove("hidden");
                lb.classList.add("flex");
                lb.setAttribute("aria-hidden", "false");
              }

              function close() {
                lb.classList.add("hidden");
                lb.classList.remove("flex");
                lb.setAttribute("aria-hidden", "true");
                lbImg.src = "";
              }

              document.querySelectorAll("[data-open]").forEach((btn) => {
                btn.addEventListener("click", () => open(parseInt(btn.dataset.open, 10)));
              });

              lb.querySelectorAll("[data-close]").forEach((el) => el.addEventListener("click", close));

              prevBtn.addEventListener("click", () => {
                idx = (idx - 1 + fronts.length) % fronts.length;
                side = "front";
                render();
              });

              nextBtn.addEventListener("click", () => {
                idx = (idx + 1) % fronts.length;
                side = "front";
                render();
              });

              flipBtn?.addEventListener("click", () => {
                if (!backs[idx]) return;
                side = (side === "front") ? "back" : "front";
                render();
              });

              window.addEventListener("keydown", (e) => {
                if (!lb || lb.classList.contains("hidden")) return;
                if (e.key === "Escape") close();
                if (e.key === "ArrowLeft") { idx = (idx - 1 + fronts.length) % fronts.length; side="front"; render(); }
                if (e.key === "ArrowRight") { idx = (idx + 1) % fronts.length; side="front"; render(); }
                if (e.key.toLowerCase() === "b") { if (!backs[idx]) return; side = (side==="front")?"back":"front"; render(); }
              });
            </script>
          </>
        )}
      </div>
    </main>
  </body>
</html>
