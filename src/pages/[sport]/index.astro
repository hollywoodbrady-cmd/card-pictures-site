---
import { loadSetsManifest } from "../../lib/sets";

export async function getStaticPaths() {
  const { manifest } = loadSetsManifest();
  return Object.keys(manifest).map((sport) => ({ params: { sport } }));
}

const { sport } = Astro.params;
const { manifest } = loadSetsManifest();

const setsObj = manifest[sport] ?? {};
const sets = Object.keys(setsObj).sort((a, b) => a.localeCompare(b));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{sport} • Card Pictures</title>
    <style>
      body { font-family: system-ui, sans-serif; margin: 0; }
      header { padding: 16px 20px; border-bottom: 1px solid #e5e5e5; }
      main { padding: 20px; max-width: 1100px; margin: 0 auto; }
      a { color: inherit; }
      .crumbs { font-size: 13px; color: #555; margin-bottom: 10px; }
      .grid { display: grid; gap: 12px; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); }
      a.card { display: block; border: 1px solid #e5e5e5; border-radius: 10px; padding: 12px; text-decoration: none; }
      a.card:hover { border-color: #bbb; }
      .set { font-weight: 700; }
      .meta { color: #666; font-size: 12px; margin-top: 4px; }
      img { width: 100%; height: 220px; object-fit: cover; border-radius: 8px; background: #f6f6f6; }
    </style>
  </head>
  <body>
    <header>
      <div style="max-width:1100px;margin:0 auto;">
        <div class="crumbs"><a href="/">Home</a> / <span style="text-transform:capitalize;">{sport}</span></div>
        <h1 style="margin:0;font-size:22px;text-transform:capitalize;">{sport}</h1>
      </div>
    </header>

    <main>
      <div class="grid">
        {sets.map((set) => {
          const imgs = setsObj[set] ?? [];
          const cover = imgs[0]?.thumb;
          return (
            <a class="card" href={`/${sport}/${set}/`}>
              {cover ? <img src={cover} loading="lazy" alt={`${set} cover`} /> : null}
              <div style="margin-top:10px;">
                <div class="set">{set}</div>
                <div class="meta">{imgs.length} image{imgs.length === 1 ? "" : "s"}</div>
              </div>
            </a>
          );
        })}
      </div>
    </main>
  </body>
</html>