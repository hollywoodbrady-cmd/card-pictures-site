---
import { loadSetsManifest } from "../lib/sets";

const { manifest, generatedAt } = loadSetsManifest();
const sports = Object.keys(manifest).sort((a, b) => a.localeCompare(b));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Card Pictures</title>
    <style>
      body { font-family: system-ui, sans-serif; margin: 0; }
      header { padding: 16px 20px; border-bottom: 1px solid #e5e5e5; }
      main { padding: 20px; max-width: 1100px; margin: 0 auto; }
      .grid { display: grid; gap: 12px; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); }
      a.card { display: block; border: 1px solid #e5e5e5; border-radius: 10px; padding: 14px; text-decoration: none; color: inherit; }
      a.card:hover { border-color: #bbb; }
      .muted { color: #666; font-size: 12px; }
      .title { font-size: 18px; font-weight: 700; margin: 0 0 4px; text-transform: capitalize; }
      .count { font-size: 13px; color: #333; }
    </style>
  </head>
  <body>
    <header>
      <div style="max-width:1100px;margin:0 auto;">
        <div style="display:flex;justify-content:space-between;align-items:baseline;gap:12px;">
          <h1 style="margin:0;font-size:20px;">Card Pictures</h1>
          {generatedAt && <span class="muted">Updated {new Date(generatedAt).toLocaleString()}</span>}
        </div>
      </div>
    </header>

    <main>
      <div class="grid">
        {sports.map((sport) => {
          const setCount = Object.keys(manifest[sport] ?? {}).length;
          return (
            <a class="card" href={`/${sport}/`}>
              <div class="title">{sport}</div>
              <div class="count">{setCount} set{setCount === 1 ? "" : "s"}</div>
            </a>
          );
        })}
      </div>
    </main>
  </body>
</html>