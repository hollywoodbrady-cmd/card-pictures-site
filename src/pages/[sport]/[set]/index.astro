---
import fs from "node:fs/promises";
import path from "node:path";

// ✅ Favorite detection
const isFavPath = (p = "") => /__fav__\.webp$/i.test(String(p));

// Normalize a setPath-like value to "/sport/set/" shape
function normSetPath(p) {
  const s = String(p ?? "");
  if (!s) return "";
  const withLeading = s.startsWith("/") ? s : `/${s}`;
  return withLeading.endsWith("/") ? withLeading : `${withLeading}/`;
}

// Extract "/sport/set/" from a card object (defensive)
function getSetPath(card) {
  return normSetPath(card?.setPath ?? card?.set ?? card?.path ?? "");
}

// Helper to get a usable thumbnail path from a card object
function getThumb(card) {
  return (
    card?.thumb ??
    card?.thumbnail ??
    card?.image ??
    card?.img ??
    card?.src ??
    card?.front ??
    ""
  );
}

// ✅ Required for static build dynamic routes
export async function getStaticPaths() {
  // During `astro build`, process.cwd() is your repo root (C:\Site\GitHub\card-gallery-site)
  const goodCardsPath = path.join(process.cwd(), "public", "good-cards.json");

  let all = [];
  try {
    const raw = await fs.readFile(goodCardsPath, "utf-8");
    const parsed = JSON.parse(raw);
    all = Array.isArray(parsed) ? parsed : [];
  } catch {
    all = [];
  }

  // Unique setPaths
  const setPaths = new Set();
  for (const c of all) {
    const sp = getSetPath(c);
    if (sp) setPaths.add(sp);
  }

  // Turn "/baseball/2025-topps-cosmic/" => { sport:"baseball", set:"2025-topps-cosmic" }
  const paths = [];
  for (const sp of setPaths) {
    const parts = sp.split("/").filter(Boolean);
    if (parts.length < 2) continue;

    const sport = parts[0];
    const set = parts.slice(1).join("/"); // supports nested sets if you ever do

    paths.push({
      params: { sport, set },
      props: { allCards: all },
    });
  }

  return paths;
}

// Page params
const { sport, set } = Astro.params;
const targetSetPath = `/${sport}/${set}/`;

// Use props passed from getStaticPaths (fast, avoids reread)
const allCards = Array.isArray(Astro.props?.allCards) ? Astro.props.allCards : [];
const cards = allCards.filter((c) => getSetPath(c) === targetSetPath);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{sport}/{set}</title>
  </head>

  <body>
    <header class="top">
      <a class="back" href="/">Home</a>
      <div class="title">
        <h1>{set}</h1>
        <div class="sub">{sport}</div>
      </div>
      <a class="back" href="/favorites/">Favorites</a>
    </header>

    {cards.length === 0 ? (
      <main class="empty">
        <p>No cards found for <code>{targetSetPath}</code>.</p>
      </main>
    ) : (
      <main class="grid">
        {cards.map((c) => {
          const thumb = getThumb(c);
          const isFavorite = isFavPath(thumb);
          const href = c?.url ?? c?.href ?? c?.link ?? targetSetPath;

          return (
            <a class={`card ${isFavorite ? "fav" : ""}`} href={href} title={c?.name ?? c?.title ?? ""}>
              <div class="imgWrap">
                {isFavorite && <span class="badge" aria-label="Favorite">★</span>}
                {thumb ? (
                  <img src={thumb} alt={c?.name ?? c?.title ?? "Card"} loading="lazy" />
                ) : (
                  <div class="missing">No image</div>
                )}
              </div>

              <div class="meta">
                <div class="name">{c?.name ?? c?.title ?? "Untitled"}</div>
                {typeof c?.score === "number" ? (
                  <div class="score">score {c.score}</div>
                ) : null}
              </div>
            </a>
          );
        })}
      </main>
    )}

    <style>
      :global(body) {
        margin: 0;
        font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      }

      .top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 16px;
        border-bottom: 1px solid rgba(0,0,0,.08);
        position: sticky;
        top: 0;
        background: white;
        z-index: 10;
      }

      .title h1 {
        margin: 0;
        font-size: 18px;
        line-height: 1.2;
        text-align: center;
      }

      .sub {
        text-align: center;
        font-size: 12px;
        opacity: 0.7;
      }

      .back {
        text-decoration: none;
        font-size: 14px;
      }

      .empty {
        padding: 24px 16px;
      }

      .grid {
        padding: 16px;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
        gap: 14px;
      }

      .card {
        display: block;
        text-decoration: none;
        color: inherit;
        border: 1px solid rgba(0,0,0,.10);
        border-radius: 10px;
        overflow: hidden;
        background: white;
      }

      .imgWrap {
        position: relative;
        aspect-ratio: 2.5 / 3.5;
        display: grid;
        place-items: center;
        background: rgba(0,0,0,.03);
      }

      .imgWrap img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }

      .missing {
        font-size: 12px;
        opacity: 0.6;
      }

      .meta {
        padding: 10px 10px 12px;
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 10px;
      }

      .name {
        font-size: 13px;
        line-height: 1.2;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        max-width: 100%;
      }

      .score {
        font-size: 12px;
        opacity: 0.7;
        white-space: nowrap;
      }

      .badge {
        position: absolute;
        top: 8px;
        left: 8px;
        font-size: 14px;
        padding: 4px 7px;
        border-radius: 999px;
        background: rgba(0,0,0,.75);
        color: white;
      }

      .card.fav {
        border-color: rgba(0,0,0,.25);
      }
    </style>
  </body>
</html>
